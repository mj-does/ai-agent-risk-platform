TG_HOST=
TG_GRAPH=
TG_SECRET=
TG_TOKEN=

# Optional: LLM second pass when regex is inconclusive or misses paraphrased attacks (requires `openai` package).
# GROQ_API_KEY=...
# OPENAI_API_KEY=...
# Set to 0 to disable only the "no-regex hit" semantic fallback (medium/suspicious paths still use LLM if keys exist).
# LLM_SEMANTIC_FALLBACK=1